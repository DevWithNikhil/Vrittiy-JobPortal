
@{
    ViewData["Title"] = "MyPostedJobs";
}

@model List<dynamic>

<div class="container mt-4">
    <h2>My Jobs & Applicants</h2>

    @foreach (var job in Model)
    {
        <div class="card p-3 mb-4">
            <h4>@job.title</h4>

            <h5>Applicants:</h5>

            @foreach (var app in job.applications)
            {
                <div class="border p-2 mb-2">
                    <p><strong>@app.name</strong></p>
                    <p>@app.email</p>

                    <a class="btn btn-sm btn-outline-light" href="/resumes/@app.resumePath" target="_blank">
                        View Resume
                    </a>
                </div>
            }
        </div>
    }
</div>