@{
    ViewData["Title"] = "MyPostedJobs";
}

@model List<dynamic>

<div class="container mt-5">

    <h2 class="mb-4 text-center">My Jobs & Applicants</h2>

    @foreach (var job in Model)
    {
        <!-- JOB CARD -->
        <div class="card mb-4">
            <div class="card-body">

                <!-- Job Title -->
                <h4 class="card-title mb-3">@job.title</h4>

                <!-- Applicants Section -->
                <h5 class="mb-3">Applicants</h5>

                @if (job.applications.Count == 0)
                {
                    <p class="text-muted">No applicants yet.</p>
                }
                else
                {
                    <div class="row">
                        @foreach (var app in job.applications)
                        {
                            <div class="col-md-6">
                                <!-- Applicant Card -->
                                <div class="card mb-3">
                                    <div class="card-body">

                                        <p class="mb-1">
                                            <strong>@app.name</strong>
                                        </p>

                                        <p class="mb-2">
                                            @app.email
                                        </p>
                                        <br />
                                        <a class="btn btn-sm btn-outline-light"
                                           href="/resumes/@app.resumePath"
                                           target="_blank">
                                            View Resume
                                        </a>

                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }

            </div>
        </div>
    }

</div>